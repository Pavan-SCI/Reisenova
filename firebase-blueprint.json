{
  "entities": {
    "Admin": {
      "title": "Admin",
      "description": "Administrator account.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string"
        }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "admins/{userId}": {
      "schema": { "$ref": "#/entities/Admin" },
      "description": "Store admin users"
    }
  }
}
